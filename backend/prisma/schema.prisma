generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Tenant {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  activeModules  TenantModule[]
  radioStations  RadioStation[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("TENANT_USER")
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Enums removed for SQLite compatibility

// Module Registry System
model ModuleDefinition {
  id          String   @id // e.g., 'radio', 'tv', 'vod'
  name        String
  description String?
  isCore      Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenants     TenantModule[]
}

model TenantModule {
  tenantId   String
  moduleId   String
  isEnabled  Boolean  @default(true)
  settings   String?    // Optional JSON config (stored as string for SQLite)

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module     ModuleDefinition @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([tenantId, moduleId])
}

// ==========================================
// RADIO MODULE SCHEMA
// ==========================================

model RadioStation {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  description  String?
  mountPoint   String   // e.g., '/live'
  port         Int      // e.g., 8000
  bitrate      Int      @default(128)
  format       String   @default("mp3") // mp3, aac
  status       String   @default("offline") // online, offline, suspended
  autoDjEnabled Boolean @default(true)
  
  // Docker container IDs
  icecastContainerId   String?
  liquidsoapContainerId String?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mediaFiles   MediaFile[]
  playlists    Playlist[]
  jingles      Jingle[]
  schedules    Schedule[]
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model MediaFile {
  id             String       @id @default(uuid())
  radioStationId String
  title          String
  artist         String?
  album          String?
  duration       Float?
  filePath       String
  fileSize       Int
  createdAt      DateTime     @default(now())

  radioStation   RadioStation @relation(fields: [radioStationId], references: [id], onDelete: Cascade)
  playlistItems  PlaylistItem[]
}

model Playlist {
  id             String       @id @default(uuid())
  radioStationId String
  name           String
  type           String       @default("standard") // standard, rotation, scheduled
  weight         Int          @default(1) // Playback weight/priority
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  radioStation   RadioStation @relation(fields: [radioStationId], references: [id], onDelete: Cascade)
  items          PlaylistItem[]
  schedules      Schedule[]
}

model PlaylistItem {
  id         String    @id @default(uuid())
  playlistId String
  mediaId    String
  sortOrder  Int       @default(0)

  playlist   Playlist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  media      MediaFile @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([playlistId, mediaId])
}

model Jingle {
  id             String       @id @default(uuid())
  radioStationId String
  name           String
  filePath       String
  triggerType    String       @default("interval") // interval, manual, top_of_hour
  intervalMins   Int?         // Play every X minutes
  
  radioStation   RadioStation @relation(fields: [radioStationId], references: [id], onDelete: Cascade)
}

model Schedule {
  id             String       @id @default(uuid())
  radioStationId String
  playlistId     String?
  name           String
  startTime      DateTime
  endTime        DateTime
  isRecurring    Boolean      @default(false)
  daysOfWeek     String?      // e.g., "1,2,3,4,5"

  radioStation   RadioStation @relation(fields: [radioStationId], references: [id], onDelete: Cascade)
  playlist       Playlist?    @relation(fields: [playlistId], references: [id], onDelete: SetNull)
}

// Note: TV, VOD, and Podcast modules will append their schema models here in future updates.
